import java.util.*;
class Main{
    public static void main(String[] args){
        Scanner sc=new Scanner (System.in);
        int a=sc.nextInt();
        int[] arr = new int[a];
        int[] temp = new int[a];
        for(int i=0;i<a;i++){
            arr[i]=sc.nextInt();
        }
        int b=sc.nextInt();
        for(int i=0;i<a;i++){
            temp[i]=arr[(i+b)%a];
        }
        for(int i=0;i<a;i++){
            System.out.print(temp[i]);
        }
    }
}
